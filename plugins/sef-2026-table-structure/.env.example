# =============================================
# DB Schema Inspector - 환경변수 설정
# 이 파일을 복사하여 .env로 저장하세요
# cp .env.example .env
# =============================================

# ---------------------------
# DB 연결 설정 (필수)
# ---------------------------

# DB 타입: postgresql | mysql | sqlite | oracle
DB_TYPE=postgresql

# PostgreSQL / MySQL / Oracle 공통
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_username
DB_PASSWORD=your_password

# SQLite 전용 (DB_TYPE=sqlite일 때)
# DB_PATH=/path/to/your/database.db

# Oracle SID 방식 사용 시 (선택, DB_NAME 대신)
# DB_SID=XE

# ---------------------------
# 타임아웃 / 재시도 설정 (선택)
# ---------------------------

# DB 연결 타임아웃 (초, 기본값: 5)
# DB_CONNECT_TIMEOUT_SEC=5

# DB 쿼리 타임아웃 (밀리초, 기본값: 10000)
# DB_QUERY_TIMEOUT_MS=10000

# MCP 툴 실행 타임아웃 (초, 기본값: 15)
# MCP_TOOL_TIMEOUT_SEC=15

# 재시도 횟수 (기본값: 1)
# DB_RETRY_COUNT=1

# 재시도 백오프 간격 (초, 기본값: 0.3)
# DB_RETRY_BACKOFF_SEC=0.3

# ---------------------------
# MySQL 설정 예시
# ---------------------------
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=your_database
# DB_USER=your_username
# DB_PASSWORD=your_password

# ---------------------------
# Oracle 설정 예시 (서비스명 방식)
# ---------------------------
# DB_TYPE=oracle
# DB_HOST=localhost
# DB_PORT=1521
# DB_NAME=ORCL
# DB_USER=your_username
# DB_PASSWORD=your_password

# ---------------------------
# Oracle 설정 예시 (SID 방식)
# ---------------------------
# DB_TYPE=oracle
# DB_HOST=localhost
# DB_PORT=1521
# DB_SID=XE
# DB_USER=your_username
# DB_PASSWORD=your_password

# ---------------------------
# SQLite 설정 예시
# ---------------------------
# DB_TYPE=sqlite
# DB_PATH=./my_database.db
